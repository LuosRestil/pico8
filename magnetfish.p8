pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--using maps
--by luos restil
spd=1
rips={}
frm=0

function _init()
	init_plr()
end

function _update()
	frm+=1
	
	plr:update()
	if rnd()<0.01 then
		add(rips,newrip(64*8+4,42*8+4))
	end

	for i=#rips,1,-1 do
		local rip=rips[i]
		rip:update()
		if(not rip.active)deli(rips,i)
	end
end

function _draw()
	cls()
	camera(-64+plr.x+7,-64+plr.y+7)
	map()
	plr:draw()
	for rip in all(rips) do
		rip:draw()
	end
end
-->8
--plr
function init_plr()
	plr={
		x=475,y=344,
		spd=1,
		sp=33,
		cnrs={
			tl={2,5,10},
			tr={5,5,10},
			br={5,7,10},
			bl={2,7,10},
		},
		anims={
			down={spd=5,frms={34,33,-34,33}},
			up={spd=5,frms={36,35,-36,35}},
			left={spd=5,frms={38,37}},
			right={spd=5,frms={-38,-37}}
		},
		anim_name="",
		anim=nil,
		animt=0,
		animf=1,

		draw=function(self)
			local pos={x=self.x,y=self.y}
			ovalfill(pos.x,pos.y+7,
				pos.x+7,pos.y+9,5)
			spr(abs(self.sp),pos.x,pos.y,1,1,self.sp<0)
		end,
		
		update=function(self)
			spd=self.spd
			local dir={x=0,y=0}
			if(btn(⬅️))dir.x-=spd
			if(btn(➡️))dir.x+=spd
			if(btn(⬆️))dir.y-=spd
			if(btn(⬇️))dir.y+=spd
			
			if dir.y>0 then
				self:set_anim("down")
			elseif dir.y<0 then
				self:set_anim("up")
			elseif dir.x<0 then
				self:set_anim("left")
			elseif dir.x>0 then
				self:set_anim("right")
			else
				local ds={"left","right","up","down"}
				local was_moving=false
				for d in all(ds) do
					if self.anim==self.anims[d] then
						self.sp=self.anim.frms[2]
						was_moving=true
						break
					end
				end
				if(was_moving)self.anim=nil
			end
			
			local newx=self.x+dir.x
			local newy=self.y+dir.y
			local movex=false
			local movey=false
			
			if dir.x~=0 then
				local offset={newx,self.y}
				local pts=dir.x>0 and
					{"tr","br"} or
					{"tl","bl"}
				local pta=add_pts(self.cnrs[pts[1]],offset)
				local ptb=add_pts(self.cnrs[pts[2]],offset)
				movex=
					walkable(pta) and
					walkable(ptb)
			end
			if dir.y~=0 then
				local offset={self.x,newy}
				local pts=dir.y>0 and
					{"bl","br"} or
					{"tl","tr"}
				local pta=add_pts(self.cnrs[pts[1]],offset)
				local ptb=add_pts(self.cnrs[pts[2]],offset)
				movey=
					walkable(pta) and
					walkable(ptb)
			end
			self.x+=movex and dir.x or 0
			self.y+=movey and dir.y or 0
			
			self:animate()
		end,
		
		animate=function(self)
			local a=self.anim
			if(a==nil)return
			self.animt+=1
			if self.animt>=a.spd then
				self.animt=0
				self.animf+=1
				if(self.animf>#a.frms)self.animf=1
			end
			self.sp=a.frms[self.animf]
		end,
		set_anim=function(self,name)
			local anim=self.anims[name]
			if anim~=self.anim then
				self.anim_name=name
				self.anim=self.anims[name]
				self.animt=0
				self.animf=1
			end
		end
	}
	plr:set_anim("down")
end

function walkable(pt)
	local ptcx=flr(pt[1]/8)
	local ptcy=flr(pt[2]/8)
	if fget(mget(ptcx,ptcy),0) then
		return false
	else
		return true
	end
end


-->8
--util
function add_pts(a,b)
	return {a[1]+b[1],a[2]+b[2]}
end
-->8
--ripple
function newrip(x,y)
	local rip={
		x=x,y=y,
		w=0,h=0,
		t=-15,lt=15,
		active=true
	}
	
	rip.update=function()
		rip.t+=1
		if rip.t>rip.lt then
			rip.active=false
			return
		end
		rip.w=rip.t*1
		rip.h=rip.t*0.4
	end
	
	rip.draw=function()
		if rip.t<0 then
			circfill(
				rip.x,rip.y+abs(rip.t)/4,
				1,6)
		else
			local woff=rip.w/2
			local hoff=rip.h/2
			oval(
				rip.x-woff,
				rip.y-hoff,
				rip.x+woff,
				rip.y+hoff,7)
		end
		
	end
	
	return rip
end
