pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
local sq1={
	x=10,y=10,w=16,h=8
}

local sq2={
	x=30,y=10,w=8,h=8
}

function _update()
	if btnp(⬆️) then
		sq2.y-=1
	elseif btnp(⬇️) then
		sq2.y+=1
	elseif btnp(⬅️) then
		sq2.x-=1
	elseif btnp(➡️) then
		sq2.x+=1
	end
end

function _draw()
	cls()
 rrect(sq1.x,sq1.y,sq1.w,sq1.h,0,8)
-- rrect(sq2.x,sq2.y,sq2.w,sq2.h,0,12)
	rect(sq2.x,sq2.y,sq2.x+sq2.w-1,sq2.y+sq2.h-1,12)
	circ(sq2.x+2,sq2.y+1,0,7)
	circ(sq2.x+4,sq2.y+1,0,7)
	circ(sq2.x+6,sq2.y+1,0,7)
	if colliding(sq1,sq2) then
		print("colliding",10,100,10)
	end
end

function colliding(a,b)
	return (
		a.x<b.x+b.w and
		b.x<a.x+a.w and
		a.y<b.y+b.h and
		b.y<a.y+a.h
	)
end
