pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
board={
	w=6,h=12
}
cell_size=10

function _init()
	grid=make_grid()
end

function _update()

end

function _draw()
	cls(1)
--	fillp(∧) --b,t,m,w
	fillp(0b0011011011000110.1)
	rectfill(0,0,127,127,2)
	
	draw_grid()
end

function make_grid()
	local g={
		x=0,y=0
	}
	for r=1,12 do
		local row={}
		for c=1,6 do
			local idx=flr(rnd()*5)
			add(row,idx)
		end
	end
	return g
end

function draw_grid()
	for r=1,12 do
		for c=1,6 do
			sspr(
				8+cell_size*grid[r][c],0,
				cell_size,cell_size,
				(c-1)*cell_size,
				(r-1)*cell_size
			)
		end
	end
end
