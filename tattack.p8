pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
board={
	w=6,h=12
}

function _init()
	grid=make_grid()
	grid.x=(128/2)-(grid.w/2)
	grid.y=(128/2)-(grid.h/2)
end

function _update()

end

function _draw()
	cls(1)
--	fillp(∧) --b,t,m,w
	fillp(0b0011011011000110.1)
	rectfill(0,0,127,127,2)
	
	draw_grid()
end

function make_grid()
	local g={
		x=0,y=0,
		cell_size=10,
		cells={},
		dim={x=6,y=12}
	}
	for r=1,g.dim.y do
		local row={}
		for c=1,g.dim.x do
			local idx=flr(rnd()*6)
			add(row,idx)
		end
		add(g.cells,row)
	end
	g.w=g.cell_size*g.dim.x
	g.h=g.cell_size*g.dim.y
	return g
end

function draw_grid()
	local cells=grid.cells
	local cs=grid.cell_size
	for r=1,12 do
		for c=1,6 do
			assert(cells[r][c]~=nil)
			sspr(
				8+cs*cells[r][c],0,
				cs,cs,
				(c-1)*cs+grid.x,
				(r-1)*cs+grid.y
			)
		end
	end
end
