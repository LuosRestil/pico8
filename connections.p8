--plr
function init_plr()
	plr={
		x=475,y=344,
		spd=1,
		sp=33,
		hb={x=2,y=5,w=4,h=3},
		cnrs={
			tl={2,5,10},
			tr={5,5,10},
			br={5,7,10},
			bl={2,7,10},
		},
		anims={
			down={spd=5,frms={2,1,-2,1}},
			up={spd=5,frms={4,3,-4,3}},
			left={spd=5,frms={6,5}},
			right={spd=5,frms={-6,-5}}
		},
		anim_name="",
		anim=nil,
		animt=0,
		animf=1,
		shadow=true,

		draw=function(self)
			local pos={x=self.x,y=self.y}
			--shadow
			if self.shadow then
				ovalfill(
					pos.x,pos.y+7,
					pos.x+7,pos.y+9,5)
			end
			
			palt(11,true)
			palt(0,false)
			--outline
			for i=1,15 do
				pal(i,0)
			end
			spr(abs(self.sp),pos.x-1,pos.y,1,1,self.sp<0)
			spr(abs(self.sp),pos.x+1,pos.y,1,1,self.sp<0)
			spr(abs(self.sp),pos.x,pos.y-1,1,1,self.sp<0)
			spr(abs(self.sp),pos.x,pos.y+1,1,1,self.sp<0)
			pal()
			palt(11,true)
			palt(0,false)
			spr(abs(self.sp),pos.x,pos.y,1,1,self.sp<0)
			palt()
			
			--debug
			if debug then
				print(
					self.x..","..self.y,
					self.x,self.y-10,
					10
				)
				rect(
					self.x+self.hb.x,
					self.y+self.hb.y,
					self.x+self.hb.x+self.hb.w-1,
					self.y+self.hb.y+self.hb.h-1,
					12)
				circ(
					self.x+self.cnrs.tl[1],
					self.y+self.cnrs.tl[2],
					0,
					self.cnrs.tl[3])
				circ(
					self.x+self.cnrs.tr[1],
					self.y+self.cnrs.tr[2],
					0,
					self.cnrs.tr[3])
				circ(
					self.x+self.cnrs.bl[1],
					self.y+self.cnrs.bl[2],
					0,
					self.cnrs.bl[3])
				circ(
					self.x+self.cnrs.br[1],
					self.y+self.cnrs.br[2],
					0,
					self.cnrs.br[3])
				end
			
		end,
		
		update=function(self)
			spd=self.spd
			local dir={x=0,y=0}
			if(btn(⬅️))dir.x-=spd
			if(btn(➡️))dir.x+=spd
			if(btn(⬆️))dir.y-=spd
			if(btn(⬇️))dir.y+=spd
			
			if dir.y>0 then
				self:set_anim("down")
				self.heading="down"
			elseif dir.y<0 then
				self:set_anim("up")
				self.heading="up"
			elseif dir.x<0 then
				self:set_anim("left")
				self.heading="left"
			elseif dir.x>0 then
				self:set_anim("right")
				self.heading="right"
			else
				local ds={"left","right","up","down"}
				local was_moving=false
				for d in all(ds) do
					if self.anim==self.anims[d] then
						self.sp=self.anim.frms[2]
						was_moving=true
						break
					end
				end
				if(was_moving)self.anim=nil
			end
			
			local newx=self.x+dir.x
			local newy=self.y+dir.y
			local movex=false
			local movey=false
			
			if dir.x~=0 then
				local offset={newx,self.y}
				local pts=dir.x>0 and
					{"tr","br"} or
					{"tl","bl"}
				local pta=add_pts(self.cnrs[pts[1]],offset)
				local ptb=add_pts(self.cnrs[pts[2]],offset)
				movex=
					walkable(pta) and
					walkable(ptb)
			end
			if dir.y~=0 then
				local offset={self.x,newy}
				local pts=dir.y>0 and
					{"bl","br"} or
					{"tl","tr"}
				local pta=add_pts(self.cnrs[pts[1]],offset)
				local ptb=add_pts(self.cnrs[pts[2]],offset)
				movey=
					walkable(pta) and
					walkable(ptb)
			end
			self.x+=movex and dir.x or 0
			self.y+=movey and dir.y or 0		

			self:animate()
			
			if debug then
				self:get_interact()
			end
			
			local i=self:get_interact()
			if i~=nil then
				if i.contact~=nil then
					i:contact()
				elseif 
					btnp(🅾️) and
					i.interact~=nil
				then
					i:interact()
				end
			end
		end,
		
		get_interact=function(self)
			if self.heading==nil then return end
			
			local rec=nil
			if self.heading=="down" then
				rec={
					x=self.x+self.hb.x,
					y=self.y+self.hb.y+self.hb.h,
					w=self.hb.w,
					h=1
				}
			elseif self.heading=="up" then
				rec={
					x=self.x+self.hb.x,
					y=self.y+self.hb.y-1,
					w=self.hb.w,
					h=1
				}
			elseif self.heading=="left" then
				rec={
					x=self.x+self.hb.x-1,
					y=self.y+self.hb.y,
					w=1,
					h=self.hb.h
				}
			elseif self.heading=="right" then
				rec={
					x=self.x+self.hb.x+self.hb.w,
					y=self.y+self.hb.y,
					w=1,
					h=self.hb.h
				}
			end
			
			self.rec=rec
			
			for i in all(ents) do
				if i==self or not i.hb then
					goto continue
				end
				
				if colliding(rec,i.hb) then
					return i
				end
				
				::continue::
			end
			
			return nil
		end,
		
		animate=function(self)
			local a=self.anim
			if(a==nil)return
			self.animt+=1
			if self.animt>=a.spd then
				self.animt=0
				self.animf+=1
				if(self.animf>#a.frms)self.animf=1
			end
			self.sp=a.frms[self.animf]
		end,
		set_anim=function(self,name)
			local anim=self.anims[name]
			if anim~=self.anim then
				self.anim_name=name
				self.anim=self.anims[name]
				self.animt=0
				self.animf=1
			end
		end
	}
	plr:set_anim("down")
end

function walkable(pt)
	local ptcx=flr(pt[1]/8)
	local ptcy=flr(pt[2]/8)
	if fget(mget(ptcx,ptcy),0) then
		return false
	else
		return true
	end
end


