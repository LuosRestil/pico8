__lua__
--connections
--by luos restil
debug=false

cam={x=0,y=0,frozen=false}
grass=112
blockgrass=116
msgs=nil
dialog=nil

state=nil
states={
	set=function(self,name,...)
		if state~=self[name] then
			state=self[name]
			if(state.init)state:init(...)
		end
	end
}

ents={}

function _init()
	states["game"]=game_state()
	states["msg"]=msg_state()
	states["dialog"]=dialog_state()
	states["trans"]=trans_state()
	states:set("game")

	init_plr()
	
	local phmap={
		[114]=new_tree,
		[100]=new_house
	}
	
	for row=0,63 do
		for col=0,127 do
			local sp=mget(col,row)
			if phmap[sp] then
				add(ents,phmap[sp](col,row))
			end
		end
	end
	
	add(ents,olaf(55,40))
	add(ents,dead_olaf(54,45))
	add(ents,exit(7,16))
	
	qsort(ents,function(a,b)
		return a.base<b.base
	end)
	
end

function _update()
	if 
		dialog==nil and
		state~=states["trans"]
	then
		states:set("game")
	elseif 
		dialog!=nil and
		state==states["game"] 
	then
		states:set("dialog")
	end
	
	state:update()
end

function _draw()
	cls()
	state:draw()
end

function new_tree(col,row)
	mset(col,row,grass)
	mset(col,row+1,blockgrass)
	mset(col+1,row+1,blockgrass)
	return {
		x=col*8,
		y=row*8,
		hb={
			x=col*8,y=(row+1)*8,
			w=16,h=8
		},
		base=(row+1)*8+7,
		w=16,h=8,
		interact=function(self)
			if col==56 then
				dialog={
					{
						msg="i'm just a tree,\nbut thanks for\nnoticing!"
					}
				}
			end
		end,
		draw=function(self)
			spr(68,self.x,self.y,2,2)
		end
	}
end

function new_house(col,row)
	for i=0,1 do
		for j=0,2 do
			mset(col+j,row+i,grass)
			mset(col+j,row+i+2,blockgrass)
		end
	end
	return {
		x=col*8,
		y=row*8,
		hb={
			x=(col+1)*8,
			y=(row+3)*8,
			w=8,h=8
		},
		base=(row+3)*8+7,
		draw=function(self)
			spr(70,self.x,self.y,3,4)
		end,
		interact=function(self)
			states:set(
				"trans",
				{x=60,y=110},
				{x=0,y=0},
				true,false)
		end
	}
end

function olaf(col,row)
	mset(col,row,blockgrass)
	return {
		x=col*8,y=row*8,
		w=8,h=8,
		hb={x=col*8,y=row*8,w=8,h=8},
		base=row*8+7,
		sp=16,
		
		draw=function(self)
			palt(0,false)
			palt(11,true)
			spr(self.sp,self.x,self.y)
			palt()
		end,
		
		interact=function(self)
			dialog={
				{msg="hi, i'm olaf,\nand i like \nwarm hugs!"},
				{
					msg="do you want to play?",
					options={
						{
							txt="yes",
							choose=function()
								dialog={{msg="hooray!"}}
							end
						},
						{
							txt="no",
							choose=function()
								dialog={
									{msg="aw, sad..."}
								}
								self.interact=function(self)
									dialog={
										{msg="..."}
									}
								end
							end
						}
					}
				}
			}
		end
	}
end

function dead_olaf(col,row)
	mset(col,row,blockgrass)
	return {
		x=col*8,
		y=row*8,
		hb={x=col*8,y=row*8,w=8,h=8},
		base=row*8+7,
		w=8,h=8,
		sp=16,
		
		draw=function(self)
			palt(0,false)
			palt(11,true)
			spr(self.sp,self.x,self.y)
			palt()
		end,
	}
end

function exit(col,row)
	return {
		hb={x=col*8,y=row*8,w=16,h=8},
		base=1,
		draw=function(self)end,
		contact=function(self)
			states:set(
				"trans",
				{x=61*8,y=39*8},
				{x=61*8-60,y=39*8-60},
				false,true)
		end
	}
end

function draw_map()
	camera(cam.x,cam.y)
	--only draw seen part of map
	local mx=flr(cam.x/8)
	local my=flr(cam.y/8)
	map(mx,my,mx*8,my*8,17,17)
end

function draw_entities()
	local ent_idx=1
	local plr_base=plr.y+7
	while ent_idx<=#ents do
		local ent=ents[ent_idx]
		if ent.base>plr_base then
			break
		end
		ent:draw()
		ent_idx+=1
	end
	
	plr:draw()
	
	for i=ent_idx,#ents do
		ents[i]:draw()
	end
	
	if debug then	
		if plr.rec then
			rectfill(plr.rec.x,plr.rec.y,
				plr.rec.x+plr.rec.w-1,
				plr.rec.y+plr.rec.h-1,
				14)
		end
	end
end
