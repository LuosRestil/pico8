pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--using maps
--by luos restil
frm=0
local cam={x=0,y=0}
trees={}
treeph=114
treesp={x=32,y=32,w=16,h=16}
grass=112
blockgrass=116

function _init()
	init_plr()
	for row=0,63 do
		for col=0,127 do
			local sp=mget(col,row)
			if sp==treeph then
				add(trees,{
					col=col,row=row,
					y=(row+1)*8+7
				})
				mset(col,row,grass)
				mset(col,row+1,blockgrass)
				mset(col+1,row+1,blockgrass)
			end
		end
	end
end

function _update()
	frm+=1
	
	plr:update()
	
	cam.x=mid(plr.x+7-64,0,1016-64)
	cam.y=mid(plr.y+7-64,0,504-64)
end

function _draw()
	cls()
	camera(cam.x,cam.y)
	--only draw seen part of map
	local mx=flr(cam.x/8)
	local my=flr(cam.y/8)
	map(mx,my,mx*8,my*8,17,17)	
	
	local tree_idx=1
	while tree_idx<=#trees do
		local tree=trees[tree_idx]
		if tree.y>plr.y+7 then
			break
		end
		draw_tree(tree)
		tree_idx+=1
	end
	
	plr:draw()
	
	for i=tree_idx,#trees do
		draw_tree(trees[i])
	end
end

function draw_tree(tree)
	--tree=col,row,y
	sspr(treesp.x,treesp.y,
		treesp.w,treesp.h,
		tree.col*8,tree.row*8)
end
-->8
--plr
function init_plr()
	plr={
		x=475,y=344,
		spd=1,
		sp=33,
		cnrs={
			tl={2,5,10},
			tr={5,5,10},
			br={5,7,10},
			bl={2,7,10},
		},
		anims={
			down={spd=5,frms={2,1,-2,1}},
			up={spd=5,frms={4,3,-4,3}},
			left={spd=5,frms={6,5}},
			right={spd=5,frms={-6,-5}}
		},
		anim_name="",
		anim=nil,
		animt=0,
		animf=1,

		draw=function(self)
			local pos={x=self.x,y=self.y}
			--shadow
			ovalfill(pos.x,pos.y+7,
				pos.x+7,pos.y+9,5)
			palt(11,true)
			palt(0,false)
			for i=1,15 do
				pal(i,0)
			end
			--outline
			spr(abs(self.sp),pos.x-1,pos.y,1,1,self.sp<0)
			spr(abs(self.sp),pos.x+1,pos.y,1,1,self.sp<0)
			spr(abs(self.sp),pos.x,pos.y-1,1,1,self.sp<0)
			spr(abs(self.sp),pos.x,pos.y+1,1,1,self.sp<0)
			pal()
			palt(11,true)
			palt(0,false)
			spr(abs(self.sp),pos.x,pos.y,1,1,self.sp<0)
			palt()
		end,
		
		update=function(self)
			spd=self.spd
			local dir={x=0,y=0}
			if(btn(⬅️))dir.x-=spd
			if(btn(➡️))dir.x+=spd
			if(btn(⬆️))dir.y-=spd
			if(btn(⬇️))dir.y+=spd
			
			if dir.y>0 then
				self:set_anim("down")
			elseif dir.y<0 then
				self:set_anim("up")
			elseif dir.x<0 then
				self:set_anim("left")
			elseif dir.x>0 then
				self:set_anim("right")
			else
				local ds={"left","right","up","down"}
				local was_moving=false
				for d in all(ds) do
					if self.anim==self.anims[d] then
						self.sp=self.anim.frms[2]
						was_moving=true
						break
					end
				end
				if(was_moving)self.anim=nil
			end
			
			local newx=self.x+dir.x
			local newy=self.y+dir.y
			local movex=false
			local movey=false
			
			if dir.x~=0 then
				local offset={newx,self.y}
				local pts=dir.x>0 and
					{"tr","br"} or
					{"tl","bl"}
				local pta=add_pts(self.cnrs[pts[1]],offset)
				local ptb=add_pts(self.cnrs[pts[2]],offset)
				movex=
					walkable(pta) and
					walkable(ptb)
			end
			if dir.y~=0 then
				local offset={self.x,newy}
				local pts=dir.y>0 and
					{"bl","br"} or
					{"tl","tr"}
				local pta=add_pts(self.cnrs[pts[1]],offset)
				local ptb=add_pts(self.cnrs[pts[2]],offset)
				movey=
					walkable(pta) and
					walkable(ptb)
			end
			self.x+=movex and dir.x or 0
			self.y+=movey and dir.y or 0
			
			self:animate()
		end,
		
		animate=function(self)
			local a=self.anim
			if(a==nil)return
			self.animt+=1
			if self.animt>=a.spd then
				self.animt=0
				self.animf+=1
				if(self.animf>#a.frms)self.animf=1
			end
			self.sp=a.frms[self.animf]
		end,
		set_anim=function(self,name)
			local anim=self.anims[name]
			if anim~=self.anim then
				self.anim_name=name
				self.anim=self.anims[name]
				self.animt=0
				self.animf=1
			end
		end
	}
	plr:set_anim("down")
end

function walkable(pt)
	local ptcx=flr(pt[1]/8)
	local ptcy=flr(pt[2]/8)
	if fget(mget(ptcx,ptcy),0) then
		return false
	else
		return true
	end
end


-->8
--util
function add_pts(a,b)
	return {a[1]+b[1],a[2]+b[2]}
end
